{
  "name": "@org/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "nx run-many --targets=build --all --parallel",
    "lint": "nx run-many --targets=lint --all --parallel",
    "test": "nx run-many --targets=test --all --parallel",
    "db:start": "docker-compose up -d",
    "db:stop": "docker-compose down",
    "db:reset": "docker-compose down -v && docker-compose up -d",
    "dev": "npm run db:start && nx run-many --targets=serve --all --parallel",
    "dev:cloud": "nx run-many --targets=serve --all --parallel"
  },
  "private": true,
  "devDependencies": {
    "@nx/js": "22.3.3",
    "@nx/maven": "^22.3.3",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "dotenv-cli": "^11.0.0",
    "nx": "22.3.3",
    "prettier": "^2.6.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2"
  },
  "workspaces": [
    "packages/*"
  ]
}
